{
  "expo": {
    "name": "SnapSort",
    "slug": "SnapSort",
    "scheme": "snapsort",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/splash-logo-light.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.snapsort.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "fetch"
        ],
        "NSPhotoLibraryUsageDescription": "SnapSort needs access to your photos to organize screenshots.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.snapsort.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/splash-logo-light.png"
      },
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-logo-light.png",
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-sqlite",
      "expo-font",
      [
        "expo-media-library",
        {
          "photosPermission": "SnapSort needs access to your photos to organize screenshots.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "owner": "sho.es",
    "extra": {
      "eas": {
        "projectId": "016d90f2-6e63-4849-9f23-21887f5b6ba4"
      }
    }
  }
}
